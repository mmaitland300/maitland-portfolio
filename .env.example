# Core: public URL + Resend (set all four for contact delivery in any environment that should send mail)
# This repo’s production canonical host is https://www.mmaitland.dev (apex redirects to www in next.config.ts).
NEXT_PUBLIC_SITE_URL=https://www.mmaitland.dev
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Optional but recommended: Upstash Redis enables server-side rate limits on contact/waitlist when
# BOTH variables are non-empty. Leave blank for local smoke runs; see README env footnote [2] and SECURITY.md.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Prisma (`prisma.config.ts`): both URLs must be set for `npm install` / `prisma generate`
# (postinstall). They do not need to reach a running server for client generation. Use placeholders
# until you configure Neon, then replace with pooled + direct URLs when enabling DB features.
DATABASE_URL=postgresql://placeholder:placeholder@127.0.0.1:5432/placeholder
DIRECT_URL=postgresql://placeholder:placeholder@127.0.0.1:5432/placeholder

# Optional: public URL for the Snake Detector live demo (projects card + case study).
# Must be http(s). When unset, the site defaults to the Gradio Space URL below; set this to override.
# Prefer the direct Gradio app URL (*.hf.space) so "Try live demo" opens the running UI.
# The Space gallery URL (https://huggingface.co/spaces/...) is valid https but lands on the overview page.
# NEXT_PUBLIC_SNAKE_DEMO_URL=https://mmaitland-snake-detector-demo.hf.space

# Optional: public URL for the Research Radar live prototype (projects card + case study).
# Must be http(s). The site uses https://radar.mmaitland.dev as the canonical default; set this to override for preview or migration deployments.
# NEXT_PUBLIC_RESEARCH_RADAR_URL=https://radar.mmaitland.dev

# Optional: shown in footer/contact sidebar; defaults to contact@mmaitland.dev in code
# NEXT_PUBLIC_CONTACT_EMAIL=

# Optional (admin + persistence): set when replacing placeholders above with Neon
# AUTH_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# ADMIN_GITHUB_IDS=
#
# Auth.js (NextAuth v5): canonical site URL for OAuth redirects. Must match the origin where you run Next.
# - Local dev: AUTH_URL=http://localhost:3000 (if you only set production URL here, Sign in will redirect to prod)
# - Production: AUTH_URL=https://www.mmaitland.dev
# AUTH_URL=
